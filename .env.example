# 請勿留空；若為空或不是合法 http(s) URL，網站會退回預設網域
NEXT_PUBLIC_SITE_URL=https://pinshiacademy.com

# WordPress (WPGraphQL)
WP_GRAPHQL_URL=https://blog.pinshiacademy.com/graphql

# Google Analytics 4（可選；填了才會載入 gtag）
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Search Console：HTML 標記驗證（可選；填了才會輸出 meta verification）
# 建議用 NEXT_PUBLIC_ 版本，讓本機/Preview 也能一致驗證（token 本身不是秘密）
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token_here

